%AXGEndBitmap
GR
GR
GS
[0.48 0 0 0.48018 356.4378 263.55511] CT
[1 0 0 1 0 0] CT
N
-560 0 M
315 0 L
315 656 L
-560 656 L
-560 0 L
cp
clip
GS
0 0 translate
315 236 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 236
  /ImageMatrix [315 0 0 236 0 0]
  /Width 315
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
