{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 450
  /ImageMatrix [1200 0 0 450 0 0]
  /Width 1200
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
